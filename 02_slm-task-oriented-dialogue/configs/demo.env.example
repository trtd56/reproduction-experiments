# Copy to .env or export these variables before running.

LFM_MODEL_ID=LiquidAI/LFM2.5-Audio-1.5B-JP
LFM_DEVICE=auto
LFM_DTYPE=auto
LFM_ENABLE_MPS=0
LFM_PRELOAD_MODEL=1
LFM_HOST=127.0.0.1
LFM_PORT=8088
LFM_RESPONSE_MODE=hybrid
LFM_SLOT_UPDATE_SOURCE=assistant
LFM_GUIDED_VALIDATE_RESPONSE=0

LFM_MAX_NEW_TOKENS=512
LFM_GUIDED_MAX_NEW_TOKENS=160
LFM_GUIDED_AUDIO_TAIL_TOKENS=48
LFM_TTS_MAX_NEW_TOKENS=192
LFM_TTS_AUDIO_CHUNK_FRAMES=3
LFM_AUDIO_TEMPERATURE=1.0
LFM_AUDIO_TOP_K=4
LFM_AUDIO_TOKEN_CHUNK_SIZE=18
LFM_TARGET_SAMPLE_RATE=24000
LFM_MIN_COMMIT_SECONDS=0.25
